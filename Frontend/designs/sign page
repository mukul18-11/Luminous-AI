<body class="font-body text-on-surface min-h-screen flex flex-col items-center justify-center p-6 overflow-hidden">
<!-- Brand Identity Anchor -->
<div class="mb-12 flex flex-col items-center">
<div class="mb-4 p-3 bg-primary/10 rounded-xl">
<span class="material-symbols-outlined text-primary text-4xl" data-icon="auto_awesome">auto_awesome</span>
</div>
<h1 class="font-headline text-3xl font-extrabold tracking-tighter text-primary">Luminescent AI</h1>
<p class="font-label text-[11px] uppercase tracking-[0.2em] text-on-surface-variant mt-2">Executive Productivity Suite</p>
</div>
<!-- Main Auth Card -->
<main class="w-full max-w-[420px] relative">
<!-- Decoration Glow -->
<div class="absolute -top-12 -left-12 w-64 h-64 bg-primary/10 blur-[100px] rounded-full pointer-events-none"></div>
<div class="absolute -bottom-12 -right-12 w-64 h-64 bg-secondary/10 blur-[100px] rounded-full pointer-events-none"></div>
<div class="glass-panel p-10 rounded-xl shadow-2xl shadow-indigo-900/20 relative z-10">
<header class="mb-10">
<h2 class="font-headline text-2xl text-on-surface tracking-tight">Welcome back</h2>
<p class="text-on-surface-variant text-sm mt-1">Access your AI-curated workspace.</p>
</header>
<form class="space-y-6">
<!-- Email Input -->
<div class="space-y-2">
<label class="font-label text-[11px] uppercase tracking-widest text-on-surface-variant ml-1">Work Email</label>
<div class="relative group">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant group-focus-within:text-primary transition-colors text-xl" data-icon="alternate_email">alternate_email</span>
<input class="w-full h-14 bg-surface-container-lowest border-none rounded-lg pl-12 pr-4 text-on-surface placeholder:text-outline-variant focus:ring-2 focus:ring-primary/40 transition-all outline-none" placeholder="executive@luminescent.ai" type="email"/>
</div>
</div>
<!-- Password Input -->
<div class="space-y-2">
<div class="flex justify-between items-center ml-1">
<label class="font-label text-[11px] uppercase tracking-widest text-on-surface-variant">Security Key</label>
<a class="font-label text-[11px] uppercase tracking-widest text-primary hover:text-secondary transition-colors" href="#">Forgot?</a>
</div>
<div class="relative group">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant group-focus-within:text-primary transition-colors text-xl" data-icon="lock">lock</span>
<input class="w-full h-14 bg-surface-container-lowest border-none rounded-lg pl-12 pr-4 text-on-surface placeholder:text-outline-variant focus:ring-2 focus:ring-primary/40 transition-all outline-none" placeholder="••••••••••••" type="password"/>
</div>
</div>
<!-- Primary Action -->
<button class="w-full h-14 mt-4 bg-gradient-to-br from-primary to-primary-container text-on-primary font-headline font-bold rounded-xl shadow-lg shadow-primary/20 hover:shadow-primary/40 active:scale-[0.98] transition-all flex items-center justify-center gap-2 group" type="submit">
<span>Login</span>
<span class="material-symbols-outlined text-xl group-hover:translate-x-1 transition-transform" data-icon="arrow_forward">arrow_forward</span>
</button>
</form>
<div class="mt-10 flex flex-col items-center gap-6">
<div class="flex items-center gap-4 w-full">
<div class="h-[1px] flex-1 bg-outline-variant/30"></div>
<span class="font-label text-[10px] text-on-surface-variant/60 uppercase tracking-tighter">Secure authentication</span>
<div class="h-[1px] flex-1 bg-outline-variant/30"></div>
</div>
<div class="flex gap-4">
<button class="w-12 h-12 rounded-lg bg-surface-container-lowest flex items-center justify-center hover:bg-surface-bright transition-colors">
<img alt="" class="w-5 h-5 opacity-80" data-alt="Google workspace brand logo icon" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAGyzRYCFgegpzfAn0_1supQq5Ec7zDOTU3HdyM1KLCK7e3pWAmD4UvSihrgb60UIej3orA7pbLlbar7uxZGcMYpksq9g-5_GFOR3jb2uIiXXW4ApkRyGsYY-xTVL_Z0RkgRivydp_LktVLNtJDnfbHoEP21wYZq79x8EfJhhJlUqkE0HKFBr79ix4Km9LDMgkO0dN3SmxpNagPxeGNo5xrTSoLr5AyB6l8xya6Tox8mOFiJwcmwvqibw1YdED4PXVZxVRS_3j55Bqp"/>
</button>
<button class="w-12 h-12 rounded-lg bg-surface-container-lowest flex items-center justify-center hover:bg-surface-bright transition-colors">
<span class="material-symbols-outlined text-on-surface-variant" data-icon="terminal">terminal</span>
</button>
</div>
<p class="text-sm text-on-surface-variant">
                    New to the executive suite? 
                    <a class="text-primary font-medium hover:underline decoration-primary/30 underline-offset-4 ml-1" href="#">Create Account</a>
</p>
</div>
</div>
</main>
<!-- Footer Identity -->
<footer class="mt-auto w-full py-8">
<div class="flex flex-col md:flex-row justify-center items-center px-12 gap-8 text-on-surface-variant/40">
<span class="font-label text-[11px] uppercase tracking-widest">© 2024 Luminescent Executive AI</span>
<div class="flex gap-6">
<a class="font-label text-[11px] uppercase tracking-widest hover:text-primary transition-colors" href="#">Privacy</a>
<a class="font-label text-[11px] uppercase tracking-widest hover:text-primary transition-colors" href="#">Terms</a>
<a class="font-label text-[11px] uppercase tracking-widest hover:text-primary transition-colors" href="#">Support</a>
</div>
</div>
</footer>
