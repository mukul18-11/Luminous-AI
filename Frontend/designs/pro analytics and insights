<span class="text-on-surface-variant text-xs font-semibold uppercase tracking-wider">Pending</span>
<span class="material-symbols-outlined text-secondary" data-icon="pending_actions">pending_actions</span>
</div>
<div class="mt-4">
<h2 class="font-headline text-3xl font-bold">4</h2>
<p class="text-on-surface-variant text-xs mt-1">Due within 48 hours</p>
</div>
</div>
<!-- Overdue -->
