<div class="absolute top-0 left-0 w-1 h-full bg-error"></div>
<div class="flex justify-between items-start">
<span class="text-on-surface-variant text-xs font-semibold uppercase tracking-wider">Overdue</span>
<span class="material-symbols-outlined text-error" data-icon="error">error</span>
</div>
<div class="mt-4">
<h2 class="font-headline text-3xl font-bold text-error">2</h2>
