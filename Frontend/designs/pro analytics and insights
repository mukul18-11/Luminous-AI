<h1 class="font-headline text-4xl font-extrabold tracking-tighter text-on-surface">Executive Insights</h1>
</div>
<div class="flex gap-3">
<button class="flex items-center gap-2 px-4 py-2 rounded-lg bg-surface-container-high text-on-surface-variant hover:bg-surface-bright transition-colors text-sm font-medium">
<span class="material-symbols-outlined text-sm" data-icon="calendar_today">calendar_today</span>
