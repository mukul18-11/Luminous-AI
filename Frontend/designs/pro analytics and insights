</div>
</div>
</header>
<!-- KPI Grid -->
<section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
<!-- Total Tasks -->
<div class="surface-container-low p-6 rounded-xl flex flex-col justify-between ai-glow">
<div class="flex justify-between items-start">
<span class="text-on-surface-variant text-xs font-semibold uppercase tracking-wider">Total Tasks</span>
<span class="material-symbols-outlined text-primary" data-icon="list_alt">list_alt</span>
</div>
<div class="mt-4">
<h2 class="font-headline text-3xl font-bold">24</h2>
<p class="text-secondary text-xs mt-1">+12% from last month</p>
</div>
</div>
<!-- Completed -->
<div class="surface-container-low p-6 rounded-xl flex flex-col justify-between">
<div class="flex justify-between items-start">
<span class="text-on-surface-variant text-xs font-semibold uppercase tracking-wider">Completed</span>
<span class="material-symbols-outlined text-green-400" data-icon="check_circle">check_circle</span>
</div>
