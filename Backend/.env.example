# Server
PORT=5000
NODE_ENV=development

# Database — replace with your MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/voicetodo?retryWrites=true&w=majority

# Authentication — change this to a strong random secret
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# OpenAI — your API key from platform.openai.com
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# CORS — frontend URL (update for production)
FRONTEND_URL=http://localhost:5173

# Email — recommended on Render (HTTP, no SMTP port blocking)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Luminous Voice <onboarding@resend.dev>

# Email — SMTP fallback (good for localhost/dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
